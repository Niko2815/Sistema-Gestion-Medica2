# Variables de entorno para Sistema Hospitalario
# Copia este archivo a .env y ajusta los valores según tu entorno

# Clave secreta de Flask (cambiar en producción)
SECRET_KEY=clave_secreta_ing_bogota_2026

# Base de datos SQL (MySQL)
# Formato: mysql+pymysql://usuario:contraseña@host:puerto/nombre_bd
# Para XAMPP con root sin contraseña:
SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:@localhost/gestion_medica

# Para Docker, usar el nombre del servicio como host:
# SQLALCHEMY_DATABASE_URI=mysql+pymysql://root:root@db:3306/gestion_medica

# Base de datos NoSQL (MongoDB)
# Formato: mongodb://usuario:contraseña@host:puerto/nombre_bd
# Para localhost (por defecto sin autenticación):
MONGO_URI=mongodb://localhost:27017/gestion_medica_nosql

# Para Docker, usar el nombre del servicio como host:
# MONGO_URI=mongodb://mongo:27017/gestion_medica_nosql

# Configuraciones opcionales
# DEBUG=True  # Solo en desarrollo
# FLASK_ENV=development
